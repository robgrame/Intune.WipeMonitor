@inherits LayoutComponentBase
@using Intune.WipeMonitor.Shared.Logging

<div class="app-layout d-flex flex-column min-vh-100">
    @* Top Navigation Bar *@
    <nav class="navbar navbar-expand-md navbar-dark app-navbar">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="">
                <span class="brand-icon me-2">🛡️</span>
                <span class="brand-title">Wipe Monitor</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            📊 Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="approvals">
                            ✅ Approvazioni
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="history">
                            📜 Storico
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="status">
                            ⚙️ Stato Servizi
                        </NavLink>
                    </li>
                </ul>

                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-light small opacity-75">👤 @context.User.Identity?.Name</span>
                            <a href="MicrosoftIdentity/Account/SignOut" class="btn btn-sm btn-outline-light">Sign Out</a>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    @* Main Content *@
    <main class="flex-grow-1">
        <div class="container-fluid px-4 py-4">
            @Body
        </div>
    </main>

    @* Footer - ispirato a 120mAGL *@
    <footer class="app-footer mt-auto border-top">
        <div class="container-fluid px-4">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center py-3 small text-muted">
                <span>
                    v@(StartupBanner.GetShortVersion("Intune.WipeMonitor"))
                    — Made with <span class="text-danger">❤️</span> by IT Pro for IT Pros
                </span>
                <span class="d-flex align-items-center gap-3 mt-2 mt-sm-0">
                    <span>
                        <a href="https://github.com/robgrame/Intune.WipeMonitor" target="_blank" rel="noopener noreferrer" class="text-muted text-decoration-none">
                            <img src="images/github-mark.svg" alt="GitHub" style="height:14px;width:auto;vertical-align:middle;" class="me-1" />GitHub
                        </a>
                    </span>
                    <span>
                        <img src="images/Azure-A.svg" alt="Azure" style="height:14px;width:auto;vertical-align:middle;" class="me-1" />Running on <strong>Azure</strong>
                    </span>
                </span>
            </div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
