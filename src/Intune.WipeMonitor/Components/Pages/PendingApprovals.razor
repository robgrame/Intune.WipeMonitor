@page "/approvals"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject CleanupOrchestrator Orchestrator

<PageTitle>Approvazioni — Wipe Monitor</PageTitle>

<h1 class="mb-4">✅ Approvazioni in Attesa</h1>

@if (pendingRecords is null)
{
    <p class="text-muted">Caricamento...</p>
}
else if (pendingRecords.Count == 0)
{
    <div class="alert alert-info">
        <strong>Nessun device in attesa di approvazione.</strong>
        I device appariranno qui dopo che il wipe è stato completato con successo.
    </div>
}
else
{
    <div class="alert alert-warning">
        <strong>@pendingRecords.Count device</strong> in attesa di approvazione per il cleanup.
        Verificare che il wipe sia stato completato prima di approvare.
    </div>

    @foreach (var record in pendingRecords)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">🖥️ @record.DeviceDisplayName</h5>
                <span class="badge bg-warning text-dark">In attesa di approvazione</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Device Owner:</dt>
                            <dd class="col-sm-7">@record.DeviceOwner</dd>

                            <dt class="col-sm-5">Wipe richiesto da:</dt>
                            <dd class="col-sm-7">@record.InitiatedBy</dd>

                            <dt class="col-sm-5">Data richiesta:</dt>
                            <dd class="col-sm-7">@record.WipeRequestedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                            <dt class="col-sm-5">Wipe completato:</dt>
                            <dd class="col-sm-7">
                                @if (record.WipeCompletedAt.HasValue)
                                {
                                    @record.WipeCompletedAt.Value.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss")
                                }
                                else
                                {
                                    <span class="text-muted">N/D</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Managed Device ID:</dt>
                            <dd class="col-sm-7"><code>@record.ManagedDeviceId</code></dd>

                            <dt class="col-sm-5">Wipe Action ID:</dt>
                            <dd class="col-sm-7"><code style="font-size: 0.8em">@record.WipeActionId</code></dd>

                            <dt class="col-sm-5">Rilevato il:</dt>
                            <dd class="col-sm-7">@record.FirstSeenAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                        </dl>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label">Note (opzionale):</label>
                    <input type="text" class="form-control mb-2" @bind="notes[record.WipeActionId]"
                           placeholder="Inserisci note per il cleanup..." />
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-success" @onclick="() => ApproveAsync(record.WipeActionId)"
                            disabled="@processing">
                        @if (processingId == record.WipeActionId)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        ✅ Approva Cleanup
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="() => SkipAsync(record.WipeActionId)"
                            disabled="@processing">
                        ⏭️ Salta
                    </button>
                </div>
            </div>
        </div>
    }
}

@* Sezione device con cleanup fallito (retry) *@
@if (failedRecords is not null && failedRecords.Count > 0)
{
    <h2 class="mt-5 mb-3">❌ Cleanup Falliti (Retry disponibile)</h2>

    @foreach (var record in failedRecords)
    {
        <div class="card mb-3 border-danger">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">🖥️ @record.DeviceDisplayName</h5>
                <span class="badge bg-danger">Fallito</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Device Owner:</dt>
                            <dd class="col-sm-7">@record.DeviceOwner</dd>

                            <dt class="col-sm-5">Approvato da:</dt>
                            <dd class="col-sm-7">@(record.ApprovedBy ?? "N/D")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        @if (record.CleanupSteps.Count > 0)
                        {
                            <strong>Dettaglio step:</strong>
                            <ul class="list-unstyled mt-1">
                                @foreach (var step in record.CleanupSteps.OrderByDescending(s => s.ExecutedAt).Take(3))
                                {
                                    <li>
                                        <span class="badge @GetStepBadgeClass(step.Result)">@step.Target</span>
                                        @step.Result
                                        @if (!string.IsNullOrEmpty(step.ErrorMessage))
                                        {
                                            <small class="text-danger">— @step.ErrorMessage</small>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-warning" @onclick="() => RetryAsync(record.WipeActionId)"
                            disabled="@processing">
                        🔄 Riprova Cleanup
                    </button>
                </div>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusAlertClass mt-3 alert-dismissible fade show">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
    </div>
}

@code {
    private List<DeviceCleanupRecord>? pendingRecords;
    private List<DeviceCleanupRecord>? failedRecords;
    private Dictionary<string, string> notes = new();
    private bool processing;
    private string? processingId;
    private string? statusMessage;
    private string statusAlertClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        pendingRecords = await Db.DeviceCleanupRecords
            .Where(r => r.Status == CleanupStatus.PendingApproval)
            .OrderByDescending(r => r.WipeCompletedAt)
            .ToListAsync();

        failedRecords = await Db.DeviceCleanupRecords
            .Include(r => r.CleanupSteps)
            .Where(r => r.Status == CleanupStatus.Failed)
            .OrderByDescending(r => r.LastUpdatedAt)
            .ToListAsync();

        foreach (var r in pendingRecords)
        {
            notes.TryAdd(r.WipeActionId, "");
        }
    }

    private async Task ApproveAsync(string wipeActionId)
    {
        processing = true;
        processingId = wipeActionId;
        StateHasChanged();

        try
        {
            notes.TryGetValue(wipeActionId, out var note);
            var success = await Orchestrator.ApproveCleanupAsync(wipeActionId, "operator", note);

            statusMessage = success
                ? $"Cleanup approvato ed eseguito con successo."
                : "Errore durante l'approvazione.";
            statusAlertClass = success ? "alert-success" : "alert-danger";
        }
        catch (Exception ex)
        {
            statusMessage = $"Errore: {ex.Message}";
            statusAlertClass = "alert-danger";
        }
        finally
        {
            processing = false;
            processingId = null;
            await LoadDataAsync();
        }
    }

    private async Task SkipAsync(string wipeActionId)
    {
        processing = true;

        try
        {
            notes.TryGetValue(wipeActionId, out var reason);
            await Orchestrator.SkipCleanupAsync(wipeActionId, "operator", reason);
            statusMessage = "Device contrassegnato come saltato.";
            statusAlertClass = "alert-info";
        }
        finally
        {
            processing = false;
            await LoadDataAsync();
        }
    }

    private async Task RetryAsync(string wipeActionId)
    {
        processing = true;
        processingId = wipeActionId;
        StateHasChanged();

        try
        {
            var success = await Orchestrator.RetryCleanupAsync(wipeActionId);
            statusMessage = success ? "Retry eseguito." : "Errore durante il retry.";
            statusAlertClass = success ? "alert-success" : "alert-danger";
        }
        finally
        {
            processing = false;
            processingId = null;
            await LoadDataAsync();
        }
    }

    private static string GetStepBadgeClass(StepResult result) => result switch
    {
        StepResult.Success => "bg-success",
        StepResult.Failed => "bg-danger",
        StepResult.NotFound => "bg-secondary",
        StepResult.Skipped => "bg-dark",
        _ => "bg-info"
    };
}
