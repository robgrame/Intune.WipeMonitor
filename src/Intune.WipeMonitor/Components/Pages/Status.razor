@page "/status"
@rendermode InteractiveServer
@implements IDisposable
@inject WipeMonitorBackgroundService BackgroundService

<PageTitle>Stato Servizi — Wipe Monitor</PageTitle>

<h1 class="mb-4">⚙️ Stato Servizi</h1>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <span class="status-led @(BackgroundService.IsRunning ? "led-green" : "led-red")"></span>
                <strong>📡 Polling Service</strong>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Stato:</dt>
                    <dd class="col-sm-7">
                        @if (BackgroundService.IsRunning)
                        {
                            <span class="badge bg-success">Attivo</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Inattivo</span>
                        }
                    </dd>
                    <dt class="col-sm-5">Ultimo polling:</dt>
                    <dd class="col-sm-7">
                        @(BackgroundService.LastPollTime?.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss") ?? "Mai")
                    </dd>
                    <dt class="col-sm-5">Ultimo errore:</dt>
                    <dd class="col-sm-7 @(!string.IsNullOrEmpty(BackgroundService.LastError) ? "text-danger" : "")">
                        @(BackgroundService.LastError ?? "Nessuno")
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    @{
        var agent = CleanupHub.ConnectedAgents.Values.FirstOrDefault();
        var agentAlive = agent is not null && agent.IsAlive;
    }

    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <span class="status-led @(agentAlive ? "led-green" : "led-red")"></span>
                <strong>🖧 Gateway Agent</strong>
            </div>
            <div class="card-body">
                @if (agent is not null)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Agent ID:</dt>
                        <dd class="col-sm-7"><strong>@agent.AgentId</strong></dd>
                        <dt class="col-sm-5">Machine:</dt>
                        <dd class="col-sm-7">@agent.MachineName</dd>
                        <dt class="col-sm-5">Versione:</dt>
                        <dd class="col-sm-7">@agent.Version</dd>
                        <dt class="col-sm-5">Connesso da:</dt>
                        <dd class="col-sm-7">@agent.ConnectedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                        <dt class="col-sm-5">Heartbeat:</dt>
                        <dd class="col-sm-7">@agent.LastHeartbeat.LocalDateTime.ToString("HH:mm:ss")</dd>
                    </dl>
                }
                else
                {
                    <p class="text-muted mb-0">Nessun agent connesso. Avviare il servizio on-prem.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-header"><strong>🔗 Connettività On-Prem</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-6 d-flex align-items-center gap-2">
                        <span class="status-led @(agentAlive && agent!.CanReachAD ? "led-green" : agentAlive ? "led-red" : "led-grey")"></span>
                        Active Directory
                    </dt>
                    <dd class="col-sm-6">
                        @if (!agentAlive)
                        {
                            <span class="text-muted">N/D</span>
                        }
                        else if (agent!.CanReachAD)
                        {
                            <span class="badge bg-success">Raggiungibile</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Non raggiungibile</span>
                        }
                    </dd>
                    <dt class="col-sm-6 d-flex align-items-center gap-2">
                        <span class="status-led @(agentAlive && agent!.CanReachSccm ? "led-green" : agentAlive ? "led-red" : "led-grey")"></span>
                        SCCM
                    </dt>
                    <dd class="col-sm-6">
                        @if (!agentAlive)
                        {
                            <span class="text-muted">N/D</span>
                        }
                        else if (agent!.CanReachSccm)
                        {
                            <span class="badge bg-success">Raggiungibile</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Non raggiungibile</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@code {
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(_ => InvokeAsync(StateHasChanged), null, 0, 5000);
    }

    public void Dispose() => _timer?.Dispose();
}
